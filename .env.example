WEB_MCP_URL=https://your-railway-url.up.railway.app/mcp
NEXT_PUBLIC_SITE_URL=https://sidelineiq.com

# Agents (Railway Express) backend. The /admin approve + promote route handlers
# call it server-to-server and forward AGENTS_API_SECRET as a Bearer token; the
# agents service rejects /admin/* without it. Must match the value set on Railway.
AGENTS_URL=https://sidelineiq-agents-production.up.railway.app
AGENTS_API_SECRET=

# ── Injury Desk auth (Phase 2) ───────────────────────────────────────────────
# NextAuth (Auth.js v5) magic-link sign-in, bound to the single physician.
AUTH_SECRET=
# Deployment origin (e.g. https://sidelineiq.vercel.app). Used for callback URLs.
AUTH_URL=
# Only this address may sign in to /desk and /admin.
ALLOWED_MD_EMAIL=kpjohnsonmd@yahoo.com
# Resend API key + a sender on a domain verified in Resend (Yahoo cannot be the from).
AUTH_RESEND_KEY=
EMAIL_FROM=no-reply@yourdomain.com
